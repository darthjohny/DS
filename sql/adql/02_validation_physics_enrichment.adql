-- Enrich validated crossmatch rows with Gaia DR3 physics and quality columns.
--
-- Что делает запрос:
--   - берёт уже провалидированные `source_id` из пользовательской таблицы;
--   - подтягивает физические параметры из `gaiadr3.astrophysical_parameters`;
--   - подтягивает quality и photometry поля из `gaiadr3.gaia_source`.
--
-- Результат использовался как вход для построения:
--   - `lab.nasa_gaia_crossmatch`;
--   - `lab.nasa_gaia_train`;
--   - дальнейшего host-training и preprocessing QA.

SELECT
    v.id,
    v.hostname,
    v.source_id,
    v.dist_arcsec,
    ap.teff_gspphot,
    ap.logg_gspphot,
    ap.radius_gspphot,
    ap.mh_gspphot,
    gs.ruwe,
    gs.parallax,
    gs.parallax_over_error,
    gs.phot_g_mean_mag,
    gs.bp_rp
FROM user_ekuzneco.validation AS v
LEFT JOIN gaiadr3.astrophysical_parameters AS ap
    ON ap.source_id = v.source_id
LEFT JOIN gaiadr3.gaia_source AS gs
    ON gs.source_id = v.source_id;
